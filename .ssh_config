Host *
  ServerAliveInterval 15
  ServerAliveCountMax 3
  ControlMaster auto
  ControlPath ~/.ssh/cm-%C
  ControlPersist 10m

Host jetson
    HostName 192.168.178.68
    User phillip
    PreferredAuthentications publickey

Host raspi5
    HostName 192.168.178.82
    User phillip
    PreferredAuthentications publickey

Host cobber
    HostName 192.168.178.40
    User cobber
    PreferredAuthentications publickey
